pipeline {
    agent {
        label 'node-agent'
        docker {
            image 'mcr.microsoft.com/playwright:v1.42.1-jammy'
            args '--network jenkins-net -u 0 -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    stages {
        stage('Setup Secrets') {
            steps {
                // This pulls your secrets from Jenkins and writes them to files
                // so Docker Compose can find them.
                withCredentials([
                    file(credentialsId: 'dockerenv.env', variable: 'ENV_FILE_PATH'),
                    file(credentialsId: 'envfile', variable: 'ENV_FILE')
                ]) {
                    sh "cp \$ENV_FILE_PATH ./dockerenv.env"
                    sh "cp \$ENV_FILE ./backend/.env"
                }
            }
        }
        stage('Install Docker Tools') {
            steps {
                echo 'Installing Docker CLI and Compose (Generic Version)...'
                // This gets the job done in 20 seconds without GPG keys
                sh '''
                    apt-get update && \
                    apt-get install -y docker.io docker-compose && \
                    docker --version && \
                    docker-compose --version
                '''
            }
        }

        stage('Run App & Tests') {
            steps {
                echo 'Starting your stack and running Playwright...'
                sh 'docker-compose up -d --build'
                sh 'npx playwright test'
            }
        }
    }

    post {
        always {
            sh 'docker-compose down'
        }
    }
}