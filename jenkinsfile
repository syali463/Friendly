pipeline {
    agent { label 'node-agent' }

    environment {
        CI = 'true'
        BACKEND_URL = "http://backend:3000"
        FRONTEND_URL = "http://web:80"
    }

    stages {
        stage('Setup Secrets') {
            steps {
                withCredentials([
                    file(credentialsId: 'dockerenv.env', variable: 'ENV_FILE_PATH'),
                    file(credentialsId: 'envfile', variable: 'ENV_FILE')
                ]) {
                    sh "cp \$ENV_FILE_PATH ./dockerenv.env"
                    sh "cp \$ENV_FILE ./backend/.env"
                }
            }
        }

        stage('Launch Stack') {
            steps {
                // Use 'docker compose' (no hyphen), the modern version
                sh 'docker compose up -d --build --wait exit-code-from test'
            }
        }

        stage('check') {
            steps {
                // Run Playwright INSIDE a temporary container on the same network
                echo '--Check WHOIAM--'
                sh 'whoami'
                echo '--Checkfilesocket--'
                sh 'ls -la /var/run/docker.sock || echo "SOCKET NOT FOUND"'
            }
        }
    }

    post {
        always {
            sh 'docker compose down'
        }
    }
}