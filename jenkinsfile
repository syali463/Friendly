pipeline {
    agent { label 'node-agent' }

    stages {
        stage('Checkout Repo') {
            steps {
                checkout scm
            }
        }

        stage('Build & Start Containers') {
            steps {
            withCredentials([file(credentialsId: 'dockerenv.env', variable: 'ENV_FILE_PATH'),file(credentialsId: 'envfile', variable: 'ENV_FILE')]) {
            sh "cp \$ENV_FILE ./backend/.env"
            sh "cp \$ENV_FILE_PATH ./dockerenv.env"
            sh "docker compose up -d --build --wait"
            sh 'docker ps'
        }
            }
        }

        stage('Run Playwright Tests') {
            steps {
                script {
                    try {
                        sh 'docker-compose exec -T playwright npx playwright test'
                    } catch (Exception e) {
                        currentBuild.result = 'UNSTABLE'
                        echo "Tests failed: ${e.message}"
                    }
                }
            }
        }
    }

    post {
        always {
            sh 'rm -f ./dockerenv.env'
            sh 'docker cp test-runner:/app/playwright-report ./playwright-report'
            
            sh 'docker compose down'

            publishHTML(target: [
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright Report'
            ])
        }
    }
}